{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/bin",
    "rootDir": "./bin",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@peptiderx/atl-verifier": ["./src/index.ts"],
      "@peptiderx/atl-verifier/pda": ["./src/pda/index.ts"]
    }
  },
  "include": ["bin/**/*"],
  "exclude": ["dist", "tests", "node_modules"]
}
