{
  "name": "@peptiderx/atl-verifier",
  "version": "0.2.0-experimental.2",
  "description": "EXPERIMENTAL · client-side verifier for ATL commit-reveal, Merkle roots, state roots, and the Peptide Design Attestation (PDA) protocol. Cross-language byte-identical with the Python and Rust reference implementations on the three frozen test vectors. Active development; APIs may change.",
  "license": "Apache-2.0",
  "author": "Peptide RX <hello@peptiderx.io>",
  "homepage": "https://peptiderx.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeptideRX/atl-verifier.git"
  },
  "bugs": {
    "url": "https://github.com/PeptideRX/atl-verifier/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pda": {
      "types": "./dist/pda/index.d.ts",
      "import": "./dist/pda/index.js"
    }
  },
  "bin": {
    "atl-verify-pda": "./dist/bin/atl-verify-pda.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-bin.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "peptide-rx",
    "atl",
    "autonomous-thesis-loop",
    "commit-reveal",
    "merkle",
    "cryptography",
    "desci",
    "peptide",
    "pda",
    "peptide-design-attestation",
    "verifier",
    "experimental"
  ],
  "publishConfig": {
    "access": "public"
  }
}
